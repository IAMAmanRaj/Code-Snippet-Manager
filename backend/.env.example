# MongoDB Connection
MONGODB_URI=mongodb://localhost:27017/snippet-manager

# Server Port (optional, defaults to 5000)
PORT=5000

# CORS Configuration
# For development, you can use: http://localhost:5173,http://localhost:3000
# For production, use your frontend URL(s) separated by commas
# Example: https://your-frontend.vercel.app,https://your-frontend-domain.com
CORS_ORIGIN=http://localhost:5173,http://localhost:3000

# Node Environment
NODE_ENV=development
